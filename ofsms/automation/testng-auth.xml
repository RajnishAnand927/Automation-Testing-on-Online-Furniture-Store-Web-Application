<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="ofsms-auth-suite">
    <listeners>
        <listener class-name="com.ofsms.tests.TestReportListener"/>
    </listeners>
    <test name="ofsms-auth-tests">
        <groups>
            <run>
                <include name="auth"/>
            </run>
        </groups>
        <packages>
            <package name="com.ofsms.tests"/>
        </packages>
    </test>
</suite>
